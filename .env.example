# Copy this file to `.env` in the project root and adjust values. Never commit `.env`.

# --- AI assistant (Inspector panel) — pick one ---
# OpenAI Cloud:
# OPENAI_API_KEY=sk-proj-...
# SNAPPI_AI_MODEL=gpt-4o-mini

# Local OpenAI-compatible server (e.g. Ollama at http://127.0.0.1:11434/v1):
# SNAPPI_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# SNAPPI_AI_MODEL=llama3.2

# --- GitHub (optional but required for some features) ---
# Private PR metadata / file list, posting comments, and "Open fix PR" (push + create PR):
# GITHUB_TOKEN=ghp_...
